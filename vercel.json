{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth-handler?__path=:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
